PROJECT_NAME=KrishiMitra AI API
API_VERSION=1.0.0
API_V1_STR=/api/v1
ENVIRONMENT=development

SECRET_KEY=replace-with-a-secure-random-string-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/krishimitra

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
